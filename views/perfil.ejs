<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil - Marketplace</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <a href="/catalogo" class="nav-logo">
            <span>✨</span> Marketplace
        </a>
        <div class="nav-links">
            <a href="/catalogo" class="nav-link">Inicio</a>
            <a href="/logout" class="nav-link nav-link-logout">Cerrar Sesión</a>
        </div>
    </nav>

    <div class="auth-wrapper">
        <div class="auth-card">
            <div style="font-size: 3rem; margin-bottom: 10px;">👤</div>
            <h2>¡Hola, <%= nombre %>!</h2>
            <p class="subtitle">Bienvenido a tu panel de control</p>
            
            <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 25px; border-left: 4px solid var(--primario);">
                <p style="margin: 0; font-size: 0.9rem; color: #666;">Rol de usuario:</p>
                <strong style="text-transform: capitalize; color: var(--oscuro);"><%= rol %></strong>
            </div>

            <div style="display: flex; flex-direction: column; gap: 10px;">
                <a href="/catalogo" class="btn-login" style="text-decoration: none;">🛒 Explorar Catálogo</a>
                
                <% if (rol === 'artesano') { %>
                    <a href="/mis-productos" class="btn-login" style="background-color: var(--secundario); text-decoration: none;">
                        🔨 Gestionar Mis Productos
                    </a>
                <% } %>
            </div>

            <div class="auth-footer">
                ¿Deseas salir? <a href="/logout" style="color: #e76f51;">Cerrar sesión de forma segura</a>
            </div>
        </div>
    </div>
</body>
</html>