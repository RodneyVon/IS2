<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Estadístico - Marketplace</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <a href="/catalogo" class="nav-logo">
            <span>✨</span> Marketplace
        </a>
        <div class="nav-links">
            <a href="/catalogo" class="nav-link">🏠 Inicio</a>
            <a href="/carrito" class="nav-link" style="position: relative;">
        🛒 Carrito
        <% if (typeof carrito !== 'undefined' && carrito && carrito.length > 0) { %>
            <span style="background: var(--primario); color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.7rem; position: absolute; top: -5px; right: -10px;">
                <%= carrito.length %>
            </span>
        <% } %>
    </a>
            
            <% if (usuario) { %>
                <% if (usuario.rol === 'artesano') { %>
                <a href="/mis-estadisticas" class="nav-link">📊 Mis Métricas</a>
                <a href="/ventas" class="nav-link">📦 Mis Ventas</a>
                <a href="/mis-productos" class="nav-link">🛠️ Mi Panel</a>
                <% } %>
                <a href="/perfil" class="nav-link">👤 Mi Perfil</a>
                <a href="/logout" class="nav-link nav-link-logout">Cerrar Sesión</a>
            <% } else { %>
                <a href="/login" class="nav-link">Iniciar Sesión</a>
            <% } %>
        </div>
    </nav>

    <div style="max-width: 1100px; margin: 40px auto; padding: 0 20px; box-sizing: border-box;">
        <header style="text-align: center; margin-bottom: 40px;">
            <h1>📊 Dashboard de Impacto Comunitario</h1>
            <p style="color: #636e72; margin-top: 5px;">Estadísticas en tiempo real del comercio y la cultura artesanal</p>
        </header>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 40px;">
            
            <div class="panel-card" style="text-align: center; padding: 25px; border-top: 4px solid #2ecc71;">
                <span style="font-size: 2.3rem;">💰</span>
                <h3 style="margin-top: 10px; color: #7f8c8d; font-size: 1rem;">Ventas Totales</h3>
                <p style="font-size: 1.8rem; font-weight: bold; color: #27ae60; margin-top: 5px;">
                    ₲ <%= estadisticas.ventasTotales.toLocaleString('es-PY') %>
                </p>
            </div>

            <div class="panel-card" style="text-align: center; padding: 25px; border-top: 4px solid var(--primario);">
                <span style="font-size: 2.3rem;">👨‍🎨</span>
                <h3 style="margin-top: 10px; color: #7f8c8d; font-size: 1rem;">Artesanos Unidos</h3>
                <p style="font-size: 1.8rem; font-weight: bold; color: var(--oscuro); margin-top: 5px;">
                    <%= estadisticas.artesanos %>
                </p>
            </div>

            <div class="panel-card" style="text-align: center; padding: 25px; border-top: 4px solid var(--primario);">
                <span style="font-size: 2.3rem;">🏺</span>
                <h3 style="margin-top: 10px; color: #7f8c8d; font-size: 1rem;">Obras Catalogadas</h3>
                <p style="font-size: 1.8rem; font-weight: bold; color: var(--oscuro); margin-top: 5px;">
                    <%= estadisticas.productos %>
                </p>
            </div>

            <div class="panel-card" style="text-align: center; padding: 25px; border-top: 4px solid var(--primario);">
                <span style="font-size: 2.3rem;">📦</span>
                <h3 style="margin-top: 10px; color: #7f8c8d; font-size: 1rem;">Stock Disponible</h3>
                <p style="font-size: 1.8rem; font-weight: bold; color: var(--oscuro); margin-top: 5px;">
                    <%= estadisticas.stockGeneral %> und.
                </p>
            </div>
        </div>

        <div style="margin-bottom: 40px;">
            <h2 style="margin-bottom: 20px; color: var(--oscuro); display: flex; align-items: center; gap: 10px; font-size: 1.5rem;">
                🔥 Las Artesanías Favoritas del Público
            </h2>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
                <% estadisticas.favoritos.forEach((prod, index) => { %>
                    <div class="panel-card" style="display: flex; align-items: center; padding: 15px; gap: 15px; position: relative;">
                        <span style="position: absolute; top: -10px; left: -10px; background: #f1c40f; color: #fff; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: bold; font-size: 0.9rem; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                            <%= index + 1 %>
                        </span>

                        <img src="/uploads/productos/<%= prod.imagen_principal || 'default-producto.png' %>" 
                             style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid var(--borde);">
                        
                        <div style="flex: 1;">
                            <h4 style="margin: 0; color: var(--oscuro); font-size: 1.1rem;"><%= prod.nombre %></h4>
                            <p style="margin: 3px 0; color: #7f8c8d; font-size: 0.9rem;">₲ <%= prod.precio.toLocaleString('es-PY') %></p>
                            <span style="background-color: #e8f8f5; color: #1e8449; padding: 3px 8px; border-radius: 12px; font-size: 0.8rem; font-weight: bold; display: inline-block; margin-top: 5px;">
                                ❤️ ¡Vendida <%= prod.veces_vendido %> veces!
                            </span>
                        </div>
                    </div>
                <% }) %>

                <% if (estadisticas.favoritos.length === 0) { %>
                    <div class="panel-card" style="grid-column: 1 / -1; text-align: center; padding: 30px; color: #999; font-style: italic;">
                        Aún no se han registrado compras para calcular las obras preferidas.
                    </div>
                <% } %>
            </div>
        </div>

        <div class="panel-card" style="padding: 25px;">
            <h2 style="margin-bottom: 20px; color: var(--oscuro); display: flex; align-items: center; gap: 10px; font-size: 1.5rem;">
                ⭐ Rubros con Mayor Variedad
            </h2>
            
            <table class="tabla-artesanal">
                <thead>
                    <tr>
                        <th>Rubro / Categoría</th>
                        <th style="text-align: center;">Cantidad de Obras Disponibles</th>
                    </tr>
                </thead>
                <tbody>
                    <% estadisticas.categorias.forEach(cat => { %>
                        <tr>
                            <td style="font-weight: 600; color: #2c3e50;"><%= cat.categoria %></td>
                            <td style="text-align: center;"><span class="badge-stock"><%= cat.cantidad %> ítems</span></td>
                        </tr>
                    <% }) %>
                    <% if (estadisticas.categorias.length === 0) { %>
                        <tr>
                            <td colspan="2" style="text-align: center; color: #999; padding: 20px;">
                                No hay suficientes datos para clasificar las categorías todavía.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>