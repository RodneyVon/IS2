<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Mi Tienda - Estadísticas</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <a href="/catalogo" class="nav-logo">✨ Marketplace</a>
        <div class="nav-links">
            <a href="/catalogo" class="nav-link">🏠Inicio</a>
            <a href="/dashboard" class="nav-link">🏛️ Comunidad</a>
            <% if (usuario.rol === 'artesano') { %>
            <a href="/ventas" class="nav-link">📦 Mis Ventas</a>
            <a href="/mis-productos" class="nav-link">🛠️ Mi Panel</a>
            <% } %>
            <a href="/perfil" class="nav-link">👤 Mi Perfil</a>
            <a href="/logout" class="nav-link nav-link-logout">Cerrar Sesión</a>
        </div>
    </nav>

    <div style="max-width: 1100px; margin: 40px auto; padding: 0 20px;">
        <header style="text-align: center; margin-bottom: 40px;">
            <h1>🏪 Panel de Control: <%= usuario.taller_nombre || 'Mi Taller Artesanal' %></h1>
            <p style="color: #636e72; margin-top: 5px;">Revisa las finanzas, stock y rendimiento de tus obras únicas</p>
        </header>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 40px;">
            
            <div class="panel-card" style="text-align: center; padding: 25px; border-top: 4px solid #2ecc71;">
                <span style="font-size: 2.3rem;">💰</span>
                <h3 style="margin-top: 10px; color: #7f8c8d; font-size: 1rem;">Mis Ingresos Totales</h3>
                <p style="font-size: 1.8rem; font-weight: bold; color: #27ae60; margin-top: 5px;">
                    ₲ <%= estadisticas.ventasTotales.toLocaleString('es-PY') %>
                </p>
            </div>

            <div class="panel-card" style="text-align: center; padding: 25px; border-top: 4px solid var(--primario);">
                <span style="font-size: 2.3rem;">🏺</span>
                <h3 style="margin-top: 10px; color: #7f8c8d; font-size: 1rem;">Mis Productos Online</h3>
                <p style="font-size: 1.8rem; font-weight: bold; color: var(--oscuro); margin-top: 5px;">
                    <%= estadisticas.productos %> modelos
                </p>
            </div>

            <div class="panel-card" style="text-align: center; padding: 25px; border-top: 4px solid var(--primario);">
                <span style="font-size: 2.3rem;">📦</span>
                <h3 style="margin-top: 10px; color: #7f8c8d; font-size: 1rem;">Mi Stock en Almacén</h3>
                <p style="font-size: 1.8rem; font-weight: bold; color: var(--oscuro); margin-top: 5px;">
                    <%= estadisticas.stockGeneral %> unidades
                </p>
            </div>
        </div>

        <div style="margin-bottom: 40px;">
            <h2 style="margin-bottom: 20px; color: var(--oscuro); font-size: 1.5rem;">🔥 Mis 3 Obras Más Populares</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
                <% estadisticas.favoritos.forEach((prod, index) => { %>
                    <div class="panel-card" style="display: flex; align-items: center; padding: 15px; gap: 15px;">
                        <img src="/uploads/productos/<%= prod.imagen_principal || 'default-producto.png' %>" 
                             style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;">
                        <div>
                            <h4 style="margin: 0; color: var(--oscuro);"><%= prod.nombre %></h4>
                            <p style="margin: 3px 0; color: #7f8c8d;">₲ <%= prod.precio.toLocaleString('es-PY') %></p>
                            <span style="background-color: #e8f8f5; color: #1e8449; padding: 3px 8px; border-radius: 12px; font-size: 0.8rem; font-weight: bold;">
                                Vendido <%= prod.veces_vendido %> veces
                            </span>
                        </div>
                    </div>
                <% }) %>
                <% if (estadisticas.favoritos.length === 0) { %>
                    <div class="panel-card" style="grid-column: 1 / -1; text-align: center; padding: 20px; color: #999;">
                        Aún no registras ventas de tus productos en el sistema.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>