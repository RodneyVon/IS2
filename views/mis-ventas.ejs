<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mis Ventas - Panel Artesano</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .estado-texto {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: bold;
            text-transform: capitalize;
            background: #f0f0f0;
            color: #333;
            margin-bottom: 5px;
        }
        .btn-editar {
            display: inline-block;
            background: #3498db;
            color: white;
            padding: 5px 10px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 0.75rem;
            margin-bottom: 5px;
        }
        .btn-editar:hover { background: #2980b9; }

        .btn-cancelar {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 6px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.75rem;
            width: 100%;
            margin-top: 5px;
            font-weight: bold;
        }
        .btn-cancelar:hover { background: #c0392b; }

        .btn-ver {
            display: block;
            margin-top: 8px;
            font-size: 0.75rem;
            color: #27ae60;
            text-decoration: underline;
        }

        .info-contacto {
            font-size: 0.8rem;
            color: #555;
            margin-top: 3px;
        }
        .etiqueta-direccion {
            font-size: 0.75rem;
            color: #2c3e50;
            background: #fdf2e9;
            padding: 4px;
            border-radius: 4px;
            border-left: 3px solid #e67e22;
            margin-top: 6px;
            display: block;
            line-height: 1.2;
        }

        /* Caja de texto para la cancelación */
        .input-motivo {
            width: 100%;
            font-size: 0.8rem;
            padding: 5px;
            border-radius: 4px;
            border: 1px solid #ccc;
            resize: none;
            box-sizing: border-box;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <nav>
        <a href="/catalogo" class="nav-logo"><span>✨</span> Marketplace</a>
        <div class="nav-links">
            <a href="/catalogo" class="nav-link">🏠Inicio</a>
    <a href="/carrito" class="nav-link" style="position: relative;">
        🛒 Carrito
        <% if (typeof carrito !== 'undefined' && carrito && carrito.length > 0) { %>
            <span style="background: var(--primario); color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.7rem; position: absolute; top: -5px; right: -10px;">
                <%= carrito.length %>
            </span>
        <% } %>
    </a>
        <a href="/dashboard" class="nav-link">🏛️ Comunidad</a>
        <% if (usuario.rol === 'artesano') { %>
        <a href="/mis-estadisticas" class="nav-link">📊 Mis Métricas</a>
        <a href="/mis-productos" class="nav-link">🛠️ Mi Panel</a>
        <% } %>
        <a href="/perfil" class="nav-link">👤 Mi Perfil</a>
        <a href="/logout" class="nav-link nav-link-logout">Cerrar Sesión</a>
        </div>
    </nav>

    <div class="catalogo-container">
        <header style="margin-bottom: 30px;">
            <h1>📈 Registro de Ventas</h1>
            <p>Aquí puedes ver quién ha comprado tus artesanías y gestionar los pedidos.</p>
        </header>

        <table style="width: 100%; background: white; border-collapse: collapse; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <thead style="background: var(--oscuro); color: white;">
                <tr>
                    <th style="padding: 15px; text-align: left;">Fecha</th>
                    <th style="padding: 15px; text-align: left;">Producto</th>
                    <th style="padding: 15px; text-align: center;">Cant.</th>
                    <th style="padding: 15px; text-align: left;">Cliente y Entrega</th>
                    <th style="padding: 15px; text-align: right;">Total</th>
                    <th style="padding: 15px; text-align: center;">Estado y Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (ventas.length > 0) { %>
                    <% ventas.forEach(venta => { %>
                        <tr style="border-bottom: 1px solid #eee; <%= venta.estado === 'cancelado' ? 'opacity: 0.6; background: #f9f9f9;' : '' %>">
                            <td style="padding: 15px; font-size: 0.85rem;"><%= venta.fecha %></td>
                            <td style="padding: 15px;"><strong><%= venta.producto_nombre %></strong></td>
                            <td style="padding: 15px; text-align: center;"><%= venta.cantidad %></td>
                            
                            <td style="padding: 15px;">
                                <strong style="color: var(--oscuro);">👤 <%= venta.cliente_nombre %></strong>
                                
                                <div class="info-contacto">
                                    📧 <a href="mailto:<%= venta.cliente_email %>" style="color: inherit; text-decoration: none;"><%= venta.cliente_email %></a>
                                </div>
                                
                                <div class="info-contacto">
                                    📞 <%= venta.telefono || 'Sin teléfono' %>
                                </div>

                                <div class="etiqueta-direccion">
                                    📍 <strong>Envío:</strong> <%= venta.direccion || 'Retiro en local' %>
                                </div>
                            </td>

                            <td style="padding: 15px; text-align: right; font-weight: bold;">
                                ₲<%= (venta.cantidad * venta.precio_unitario).toLocaleString('es-PY') %>
                            </td>

                            <td style="padding: 15px; text-align: center;">
                                <div class="estado-texto">
                                    <%= venta.estado %>
                                </div>
                                
                                <% if (venta.estado !== 'cancelado') { %>
                                    <br>
                                    <a href="/ventas/editar/<%= venta.pedido_id %>" class="btn-editar">
                                        ✏️ Editar Estado
                                    </a>

                                    <form action="/ventas/cancelar/<%= venta.pedido_id %>" method="POST" onsubmit="return confirm('¿Seguro que quieres cancelar esta venta?')" style="margin-top: 5px; max-width: 200px; display: inline-block; text-align: left;">
                                        <textarea 
                                            name="comentario" 
                                            class="input-motivo"
                                            placeholder="Motivo del rechazo (ej. Comprobante falso)" 
                                            rows="2" 
                                            required></textarea>
                                        <button type="submit" class="btn-cancelar">
                                            ❌ Cancelar Venta
                                        </button>
                                    </form>
                                <% } else { %>
                                    <br><strong style="color: #e74c3c; font-size: 0.8rem;">ANULADA</strong>
                                <% } %>

                                <% if (venta.comprobante_ruta) { %>
                                    <a href="/uploads/<%= venta.comprobante_ruta %>" target="_blank" class="btn-ver">
                                        👁️ Ver Comprobante
                                    </a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" style="padding: 30px; text-align: center; color: #999;">Aún no has realizado ventas.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>