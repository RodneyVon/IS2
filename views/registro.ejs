<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crear Cuenta - Marketplace</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <h2>🌿 Únete a nosotros</h2>
            <p class="subtitle">Crea tu cuenta para empezar a comprar o vender</p>

            <form action="/registro" method="POST">
                <div class="form-group">
                    <label>Nombre Completo</label>
                    <input type="text" name="nombre" placeholder="Ej: Juan Pérez" required>
                </div>

                <div class="form-group">
                    <label>Correo Electrónico</label>
                    <input type="email" name="email" placeholder="ejemplo@correo.com" required>
                </div>

                <div class="form-group">
                    <label>Contraseña</label>
                    <input type="password" name="password" placeholder="Mínimo 6 caracteres" required>
                </div>

                <div class="form-group">
                    <label>Tipo de Cuenta</label>
                    <select name="rol" id="rolSelect" required onchange="toggleArtesanoFields()">
                        <option value="cliente">Quiero Comprar (Cliente)</option>
                        <option value="artesano">Quiero Vender (Artesano)</option>
                    </select>
                </div>

                <!-- SECCIÓN DINÁMICA: Solo para Artesanos -->
                <div id="camposArtesano" style="display: none; border-left: 3px solid #2ecc71; padding-left: 15px; margin-bottom: 20px;">
                    <div class="form-group">
                        <label>Nombre de tu Taller / Tienda</label>
                        <input type="text" name="taller_nombre" id="taller_nombre" placeholder="Ej: Arte en Madera López">
                    </div>

                    <div class="form-group">
                        <label>Historia de tu Taller (Bio)</label>
                        <textarea name="bio" id="bio" placeholder="Cuéntanos un poco sobre lo que haces..." style="width: 100%; min-height: 80px;"></textarea>
                    </div>
                </div>

                <button type="submit" class="btn-login">Crear Mi Cuenta</button>
            </form>

            <div class="auth-footer">
                ¿Ya tienes una cuenta? <a href="/login">Inicia sesión aquí</a>
            </div>
        </div>
    </div>

    <!-- SCRIPT PARA MOSTRAR/OCULTAR CAMPOS -->
    <script>
        function toggleArtesanoFields() {
            const rolSelect = document.getElementById('rolSelect');
            const camposArtesano = document.getElementById('camposArtesano');
            const tallerInput = document.getElementById('taller_nombre');
            
            if (rolSelect.value === 'artesano') {
                camposArtesano.style.display = 'block';
                tallerInput.setAttribute('required', 'true'); // Hacerlo obligatorio si es artesano
            } else {
                camposArtesano.style.display = 'none';
                tallerInput.removeAttribute('required'); // No es obligatorio para clientes
            }
        }
    </script>
</body>
</html>