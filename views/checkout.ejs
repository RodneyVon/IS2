<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Finalizar Compra - Datos de Envío</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="catalogo-container">
        <div class="auth-card" style="max-width: 600px; margin: 0 auto;">
            <h2>Confirmar tu Pedido</h2>
            <p>Por favor, completa los datos para la entrega.</p>

            <form action="/carrito/finalizar" method="POST">
                <div class="form-group">
                    <label>Dirección de Envío Completa</label>
                    <input type="text" name="direccion" placeholder="Calle, ciudad, número de casa..." required>
                </div>

                <div class="form-group">
                    <label>Teléfono de Contacto</label>
                    <input type="tel" name="telefono" placeholder="Ej: 0981 123 456" required>
                </div>

                <div class="form-group">
                    <label>Método de Pago</label>
                    <select name="metodo_pago" readonly>
                        <option value="Transferencia">Transferencia Bancaria (Único disponible)</option>
                    </select>
                    <small style="color: #666;">* Los datos de la cuenta se enviarán al confirmar.</small>
                </div>

                <div style="background: #f9f9f9; padding: 15px; border-radius: 10px; margin: 20px 0;">
                    <p style="margin: 0; display: flex; justify-content: space-between;">
                        <span>Total a pagar:</span>
                        <strong>₲<%= total.toLocaleString() %></strong>
                    </p>
                </div>

                <button type="submit" class="btn-login">Confirmar y Realizar Pedido</button>
                <a href="/carrito" style="display: block; text-align: center; margin-top: 15px; color: #666;">Cancelar</a>
            </form>
        </div>
    </div>
</body>
</html>